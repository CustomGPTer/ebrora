generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  USER
  ADMIN
}

enum SubscriptionTier {
  FREE
  STANDARD
  PROFESSIONAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

enum FieldType {
  TEXT
  DROPDOWN
}

enum QuestionGroup {
  PROJECT_DETAILS
  ACTIVITY_ENVIRONMENT
  CONTROLS_PPE
  METHOD_LOGISTICS
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PromptType {
  BASE
  FORMAT_VARIANT
}

// NextAuth.js Tables (following @auth/prisma-adapter conventions)
model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Core User Model (extended)
model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String?
  password_hash       String?
  google_id           String?  @unique
  email_verified      Boolean  @default(false)
  email_verified_at   DateTime?
  role                Role     @default(USER)
  onboarding_complete Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  // Relations
  accounts            Account[]
  sessions            Session[]
  subscription        Subscription?
  generations         Generation[]
  saved_details       SavedDetails?
  logos               Logo[]
  usage_records       UsageRecord[]

  @@index([email])
  @@index([google_id])
  @@map("users")
}

// Subscription Model
model Subscription {
  id                      String             @id @default(cuid())
  user_id                 String             @unique
  tier                    SubscriptionTier   @default(FREE)
  status                  SubscriptionStatus @default(ACTIVE)
  paypal_subscription_id  String?            @unique
  current_period_start    DateTime?
  current_period_end      DateTime?
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([tier])
  @@index([status])
  @@map("subscriptions")
}

// Generation Model
model Generation {
  id                String           @id @default(cuid())
  user_id           String
  format_id         String
  status            GenerationStatus @default(QUEUED)
  activity_category String?
  error_message     String?
  retry_count       Int              @default(0)
  created_at        DateTime         @default(now())
  completed_at      DateTime?
  questions         String?   @db.Text
  answers           String?   @db.Text
  blobUrl           String?
  blobPathname      String?
  filename          String?
  expiresAt         DateTime?

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  rams_format RamsFormat @relation(fields: [format_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([format_id])
  @@index([status])
  @@index([created_at])
  @@index([expiresAt])
  @@map("generations")
}

// RAMS Format Model
model RamsFormat {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  scoring_type    String   // e.g., "5x5", "HML", "RPN"
  description     String?
  is_free         Boolean  @default(false)
  enabled         Boolean  @default(true)
  columns         Json?    // JSON configuration for columns
  sections        Json?    // JSON configuration for sections
  placeholder_map Json?    // JSON mapping placeholders to values
  template_path   String?
  preview_image   String?
  order           Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  generations Generation[]
  system_prompts SystemPrompt[]

  @@index([slug])
  @@index([is_free])
  @@index([enabled])
  @@index([order])
  @@map("rams_formats")
}

// Question Model
model Question {
  id             String        @id @default(cuid())
  text           String
  field_type     FieldType
  options        Json?         // JSON array of options (for DROPDOWN type)
  word_limit     Int?
  group          QuestionGroup
  display_order  Int
  active         Boolean       @default(true)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  @@index([group])
  @@index([display_order])
  @@index([active])
  @@map("questions")
}

// Saved Details Model (company/site info)
model SavedDetails {
  id                   String   @id @default(cuid())
  user_id              String   @unique
  company_name         String?
  site_address         String?
  supervisor           String?
  principal_contractor String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("saved_details")
}

// System Prompt Model
model SystemPrompt {
  id          String     @id @default(cuid())
  type        PromptType
  format_id   String?
  content     String     @db.Text
  version     Int        @default(1)
  active      Boolean    @default(true)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  rams_format RamsFormat? @relation(fields: [format_id], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([format_id])
  @@index([active])
  @@map("system_prompts")
}

// Promo Code Model
model PromoCode {
  id                String      @id @default(cuid())
  code              String      @unique
  discount_type     DiscountType
  discount_value    Float
  expires_at        DateTime?
  usage_limit       Int?
  times_used        Int         @default(0)
  applicable_tiers  Json?       // JSON array of applicable tiers
  active            Boolean     @default(true)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  @@index([code])
  @@index([active])
  @@map("promo_codes")
}

// Cross-Sell Tag Model
model CrossSellTag {
  id            String   @id @default(cuid())
  keyword       String   @unique
  product_name  String
  product_url   String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([keyword])
  @@map("cross_sell_tags")
}

// Usage Record Model
model UsageRecord {
  id                   String   @id @default(cuid())
  user_id              String
  billing_period_start DateTime
  billing_period_end   DateTime
  rams_generated       Int      @default(0)
  rams_limit           Int
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([billing_period_start])
  @@map("usage_records")
}

// Logo Model
model Logo {
  id                String   @id @default(cuid())
  user_id           String
  file_path         String
  original_filename String
  width             Int?
  height            Int?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("logos")
}

// ============================================================
// CONTENT MODELS — Toolbox Talks, Free Templates, Free Tools
// Added for /toolbox-talks, /free-templates, /tools routes
// ============================================================

// ============================================================
// CONTENT MODELS - Append to existing prisma/schema.prisma
// ============================================================

// --- Toolbox Talks ---

model ToolboxCategory {
  id          String        @id @default(cuid())
  code        String        @unique // e.g. "02.02.01"
  name        String        // e.g. "Working at Height"
  slug        String        @unique // e.g. "working-at-height"
  description String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  talks       ToolboxTalk[]

  @@map("toolbox_categories")
}

model ToolboxTalk {
  id          String           @id @default(cuid())
  categoryId  String
  category    ToolboxCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title       String           // e.g. "Ladder Safety Essentials"
  slug        String           // e.g. "ladder-safety-essentials"
  description String?
  fileName    String?          // original file name
  blobUrl     String?          // Vercel Blob URL
  fileSize    Int?             // bytes
  isFree      Boolean          @default(true)
  isPublished Boolean          @default(true)
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  downloads   ContentDownload[]

  @@unique([categoryId, slug])
  @@map("toolbox_talks")
}

// --- Free Templates ---

enum TemplateFormat {
  EXCEL
  WORD
  POWERPOINT
}

model FreeTemplateCategory {
  id          String           @id @default(cuid())
  name        String           // e.g. "Health & Safety"
  slug        String           // e.g. "health-and-safety"
  format      TemplateFormat   // EXCEL, WORD, or POWERPOINT
  description String?
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  templates   FreeTemplate[]

  @@unique([format, slug])
  @@map("free_template_categories")
}

model FreeTemplate {
  id          String                @id @default(cuid())
  categoryId  String
  category    FreeTemplateCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  description String?
  fileName    String?
  blobUrl     String?
  fileSize    Int?
  isPublished Boolean               @default(true)
  order       Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  downloads   ContentDownload[]

  @@unique([categoryId, slug])
  @@map("free_templates")
}

// --- Free Tools ---

enum ToolStatus {
  COMING_SOON
  LIVE
}

model FreeTool {
  id          String     @id @default(cuid())
  name        String     // e.g. "Manual Handling Risk Score Calculator"
  slug        String     @unique // e.g. "manual-handling-calculator"
  description String?
  features    String?    // comma-separated key features
  status      ToolStatus @default(COMING_SOON)
  route       String?    // e.g. "/tools/manual-handling-calculator"
  gumroadUrl  String?    // link to the Excel version on Gumroad
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("free_tools")
}

// --- Tracking ---

enum ContentType {
  TOOLBOX_TALK
  FREE_TEMPLATE
}

model ContentDownload {
  id              String          @id @default(cuid())
  contentType     ContentType
  toolboxTalkId   String?
  toolboxTalk     ToolboxTalk?    @relation(fields: [toolboxTalkId], references: [id], onDelete: SetNull)
  freeTemplateId  String?
  freeTemplate    FreeTemplate?   @relation(fields: [freeTemplateId], references: [id], onDelete: SetNull)
  userId          String?
  email           String?
  ipAddress       String?
  downloadedAt    DateTime        @default(now())

  @@map("content_downloads")
}

model EmailCapture {
  id        String   @id @default(cuid())
  email     String
  name      String?
  source    String?  // e.g. "toolbox-talk-download", "free-template-download", "tool-notify"
  sourceId  String?  // the content ID that triggered the capture
  createdAt DateTime @default(now())

  @@map("email_captures")
}
